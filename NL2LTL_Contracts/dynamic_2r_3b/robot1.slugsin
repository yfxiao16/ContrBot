[INPUT]
r1_task
r1_at_pickup
r1_has_box
r1_at_delivery
r1_delivered
all_done



[OUTPUT]
r1_go_pickup
r1_pick
r1_go_delivery
r1_drop
r1_done



[ENV_TRANS]
| ! r1_go_pickup r1_at_pickup
| ! r1_pick r1_has_box
| ! r1_go_delivery r1_at_delivery
| ! r1_drop r1_delivered
| ! & r1_task ! r1_delivered r1_task'
| ! all_done all_done'


[ENV_INIT]
! r1_task
! r1_at_pickup
! r1_has_box
! r1_at_delivery
! r1_delivered
! all_done


[ENV_LIVENESS]
| r1_task all_done


