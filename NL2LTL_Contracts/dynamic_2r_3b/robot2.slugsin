[INPUT]
r2_task
r2_at_pickup
r2_has_box
r2_at_delivery
r2_delivered
all_done



[OUTPUT]
r2_go_pickup
r2_pick
r2_go_delivery
r2_drop
r2_done



[ENV_TRANS]
| ! r2_go_pickup r2_at_pickup
| ! r2_pick r2_has_box
| ! r2_go_delivery r2_at_delivery
| ! r2_drop r2_delivered
| ! & r2_task ! r2_delivered r2_task'
| ! all_done all_done'


[ENV_INIT]
! r2_task
! r2_at_pickup
! r2_has_box
! r2_at_delivery
! r2_delivered
! all_done


[ENV_LIVENESS]
| r2_task all_done


